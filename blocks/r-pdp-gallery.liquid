{%- liquid
  # Rocky-owned PDP gallery. Composes Horizon's proven carousel engine
  # (<media-gallery> / <slideshow-component> + Scroller) by delegating to the
  # upstream `product-media-gallery-content` renderer in forced carousel mode.
  # We own the framing/CSS layer below — that is where the premium feel lives;
  # the engine already handles scroll-snap, drag, thumbnail auto-centering,
  # a11y, zoom, variant-swap, 3D/video, and the iOS Safari compositor safeguard.
  assign scheme = block.settings.color_scheme
  if block.settings.inherit_color_scheme
    assign scheme = section.settings.color_scheme
  endif
-%}

<div class="r-pdp-gallery color-{{ scheme }}" {{ block.shopify_attributes }}>
  {%- render 'product-media-gallery-content',
    media_presentation: 'carousel',
    block_settings: block.settings,
    block_id: block.id,
    block_shopify_attributes: block.shopify_attributes,
    block: block,
    section: section
  -%}
</div>

{% stylesheet %}
  /* Non-invasive wrapper: display:contents keeps the engine's sticky/grid and
     scroll behavior untouched while still giving Rocky a scheme class + a CSS
     scoping hook. Colour-scheme custom properties still cascade to children. */
  .r-pdp-gallery {
    display: contents;
  }

  /* --- Thumbnail rail: floated over the hero ------------------------------ */

  /* Elevated treatment — the rail sits ON the media rather than beneath it, so
     the hero keeps the full frame. The rail is a translucent "glass" pill so it
     reads over any artwork; the blur is progressive enhancement (the tint alone
     carries contrast where backdrop-filter is unsupported). */
  .r-pdp-gallery media-gallery {
    position: relative;
  }

  /* Sticky, not absolute: the rail is pulled up over the foot of the media by a
     negative margin, then pins to the bottom of the viewport while the (full
     height) hero scrolls past — so the previews stay reachable without capping
     the media's height.

     The negative margin is what makes the rail come to rest OVER the slide.
     Sticky travel is bounded by the containing block (<slideshow-component>);
     without the pull-up the rail contributes its own height to that block, so
     the container ends BELOW the slide and the rail settles in the white space
     under the image. Pulling it up by its own height + inset keeps the
     container's bottom flush with the slide, so the rail's final resting place
     overlaps the slide contents.

     --r-pdp-gallery-rail-height should track the rendered rail height (rail =
     thumbnail height + the container's padding); 6rem matches the 64px
     thumbnails currently configured. */
  .r-pdp-gallery media-gallery slideshow-controls[thumbnails] {
    position: sticky;
    z-index: var(--layer-raised, 2);
    bottom: var(--r-pdp-gallery-rail-inset, 1rem);
    margin-block-start: calc(
      (var(--r-pdp-gallery-rail-height, 6rem) + var(--r-pdp-gallery-rail-inset, 1rem)) * -1
    );
    width: auto;
    min-height: 0;
    pointer-events: none; /* re-enabled on the pill so the hero stays clickable */
  }

  .r-pdp-gallery media-gallery slideshow-controls[thumbnails] .slideshow-controls__thumbnails-container {
    width: fit-content;
    max-width: calc(100% - (var(--r-pdp-gallery-rail-inset, 1rem) * 2));
    margin-inline: auto;
    pointer-events: auto;
    border-radius: 0;
    background: rgb(0 0 0 / 0.28);
    box-shadow: 0 2px 12px rgb(0 0 0 / 0.18);
  }

  @supports (backdrop-filter: blur(1px)) {
    .r-pdp-gallery media-gallery slideshow-controls[thumbnails] .slideshow-controls__thumbnails-container {
      background: rgb(0 0 0 / 0.18);
      backdrop-filter: blur(12px);
    }
  }

  /* Square corners throughout — thumbnails, their images, and the rail. */
  .r-pdp-gallery .slideshow-controls__thumbnails .slideshow-control,
  .r-pdp-gallery .slideshow-controls__thumbnails .slideshow-control img {
    border-radius: 0;
  }

  /* Tighter, more editorial spacing than the stock rail. */
  .r-pdp-gallery .slideshow-controls__thumbnails {
    gap: var(--r-space-2xs, 8px);
    padding: var(--r-space-2xs, 8px);
  }

  /* Soft dim on inactive thumbs; full presence on hover/active. */
  .r-pdp-gallery .slideshow-controls__thumbnail {
    opacity: 0.5;
    transition: opacity 0.25s ease;
  }

  .r-pdp-gallery .slideshow-controls__thumbnail:hover,
  .r-pdp-gallery .slideshow-controls__thumbnail:focus-visible {
    opacity: 0.8;
  }

  .r-pdp-gallery .slideshow-controls__thumbnail[aria-selected='true'] {
    opacity: 1;
  }

  /* Refined active indicator: a single thin ring rather than the stock
     outline + border pairing — reads cleaner against product imagery.
     Sitting on the dark glass pill, the ring is light rather than the page
     foreground, which would disappear against it.
     Higher specificity than the stock rule (extra .r-pdp-gallery scope). */
  .r-pdp-gallery .slideshow-controls__thumbnails .slideshow-control[aria-selected='true'] {
    outline: 1.5px solid rgb(var(--color-white-rgb) / 0.95);
    outline-offset: 2px;
    border: none;
  }

  /* Keyboard focus must stay clearly visible over arbitrary artwork. Doubling a
     light ring with a dark halo keeps it legible on both light and dark media,
     where a single-colour ring can vanish. */
  .r-pdp-gallery .slideshow-controls__thumbnail:focus-visible {
    outline: var(--focus-outline-width, 2px) solid rgb(var(--color-white-rgb) / 1);
    outline-offset: 2px;
    box-shadow: 0 0 0 calc(var(--focus-outline-width, 2px) + 2px) rgb(0 0 0 / 0.55);
  }

  @media (prefers-reduced-motion: reduce) {
    .r-pdp-gallery .slideshow-controls__thumbnail {
      transition: none;
    }
  }

  /* --- Media sizing ------------------------------------------------------- */

  /* The hero is deliberately NOT height-constrained: it runs at its full size
     (the aspect ratio drives the box, the column drives the width) rather than
     being shrunk to fit above the fold. Thumbnail access is preserved by the
     sticky rail above, not by capping the media. */
  .r-pdp-gallery media-gallery .product-media-container :is(img, video, model-viewer, iframe) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Square corners on the media itself. */
  .r-pdp-gallery media-gallery .product-media-container,
  .r-pdp-gallery media-gallery .product-media-container :is(img, video, model-viewer, iframe) {
    border-radius: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.r_pdp_gallery",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "t:content.media"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "t:settings.aspect_ratio",
      "options": [
        { "value": "adapt", "label": "t:options.auto" },
        { "value": "1/1.25", "label": "t:options.portrait" },
        { "value": "1", "label": "t:options.square" },
        { "value": "2/1", "label": "t:options.landscape" }
      ],
      "default": "1/1.25"
    },
    {
      "type": "checkbox",
      "id": "constrain_to_viewport",
      "label": "t:settings.limit_media_to_screen_height",
      "info": "t:settings.r_pdp_gallery_constrain_info",
      "default": false
    },
    {
      "type": "select",
      "id": "media_fit",
      "label": "t:settings.media_fit",
      "options": [
        { "value": "cover", "label": "t:options.cover" },
        { "value": "contain", "label": "t:options.contain" }
      ],
      "default": "contain",
      "visible_if": "{{ block.settings.aspect_ratio == 'adapt' and block.settings.constrain_to_viewport == true }}"
    },
    {
      "type": "range",
      "id": "media_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "extend_media",
      "label": "t:settings.extend_media_to_screen_edge",
      "info": "t:settings.r_pdp_gallery_extend_info",
      "default": false,
      "visible_if": "{{ section.settings.content_width == 'content-center-aligned' }}"
    },
    {
      "type": "checkbox",
      "id": "zoom",
      "label": "t:settings.enable_zoom",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_variants",
      "label": "t:settings.hide_unselected_variant_media",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "t:settings.enable_video_looping",
      "default": false
    },
    {
      "type": "header",
      "content": "t:content.carousel"
    },
    {
      "type": "select",
      "id": "icons_style",
      "label": "t:settings.icons",
      "options": [
        { "value": "arrow", "label": "t:options.arrows" },
        { "value": "chevron", "label": "t:options.chevrons" },
        { "value": "arrows_large", "label": "t:options.large_arrows" },
        { "value": "chevron_large", "label": "t:options.large_chevrons" }
      ],
      "default": "arrow"
    },
    {
      "type": "select",
      "id": "slideshow_controls_style",
      "label": "t:settings.desktop_pagination",
      "options": [
        { "value": "dots", "label": "t:options.dots" },
        { "value": "counter", "label": "t:options.counter" },
        { "value": "thumbnails", "label": "t:options.thumbnails" }
      ],
      "default": "thumbnails"
    },
    {
      "type": "select",
      "id": "slideshow_mobile_controls_style",
      "label": "t:settings.mobile_pagination",
      "options": [
        { "value": "dots", "label": "t:options.dots" },
        { "value": "counter", "label": "t:options.counter" },
        { "value": "hint", "label": "t:options.hint" },
        { "value": "thumbnails", "label": "t:options.thumbnails" }
      ],
      "default": "thumbnails"
    },
    {
      "type": "header",
      "content": "t:content.thumbnails",
      "visible_if": "{{ block.settings.slideshow_controls_style == 'thumbnails' or block.settings.slideshow_mobile_controls_style == 'thumbnails' }}"
    },
    {
      "type": "select",
      "id": "thumbnail_position",
      "label": "t:settings.desktop_position",
      "options": [
        { "value": "left", "label": "t:options.left" },
        { "value": "bottom", "label": "t:options.bottom" },
        { "value": "right", "label": "t:options.right" }
      ],
      "default": "bottom",
      "visible_if": "{{ block.settings.slideshow_controls_style == 'thumbnails' }}"
    },
    {
      "type": "range",
      "id": "thumbnail_width",
      "label": "t:settings.width_desktop",
      "min": 44,
      "max": 72,
      "step": 1,
      "unit": "px",
      "default": 64,
      "visible_if": "{{ block.settings.slideshow_controls_style == 'thumbnails' }}"
    },
    {
      "type": "range",
      "id": "thumbnail_radius",
      "label": "t:settings.corner_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.slideshow_controls_style == 'thumbnails' or block.settings.slideshow_mobile_controls_style == 'thumbnails' }}"
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "t:settings.inherit_color_scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.r_pdp_gallery",
      "category": "Rocky — PDP",
      "settings": {
        "aspect_ratio": "1/1.25",
        "constrain_to_viewport": false,
        "media_radius": 0,
        "extend_media": false,
        "zoom": true,
        "hide_variants": true,
        "slideshow_controls_style": "thumbnails",
        "slideshow_mobile_controls_style": "thumbnails",
        "thumbnail_position": "bottom",
        "thumbnail_width": 64,
        "thumbnail_radius": 0,
        "inherit_color_scheme": true
      }
    }
  ]
}
{% endschema %}
