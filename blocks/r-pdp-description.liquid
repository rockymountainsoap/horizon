{%- liquid
  assign product = closest.product
  assign variant = product.selected_or_first_available_variant

  # Honour the legacy "<!-- split -->" convention so curated PDP copy can
  # interleave hero blurb / detail blurb without a metafield split.
  assign description_parts = product.description | split: '<!-- split -->'
  assign description_top = description_parts | first | strip
  assign description_bottom = ''
  if description_parts.size > 1
    assign description_bottom = description_parts | last | strip
  endif
-%}

<script src="{{ 'r-read-more.js' | asset_url }}" type="module"></script>

<r-read-more class="r-pdp-description" data-expanded="false" {{ block.shopify_attributes }}>
  <div class="r-pdp-description__content" ref="content">
    {%- if description_top != blank -%}
      <div class="r-pdp-description__rte">{{ description_top }}</div>
    {%- endif -%}

    {%- if description_bottom != blank -%}
      <div class="r-pdp-description__rte">{{ description_bottom }}</div>
    {%- endif -%}

    {%- if product.type == 'Slab of Soap' -%}
      <p class="r-pdp-description__note">{{ 'rocky.pdp_description.slab_of_soap' | t }}</p>
    {%- endif -%}

    {%- for tag in product.tags -%}
      {%- if tag contains 'bath bomb offer' -%}
        <p class="r-pdp-description__promo">{{ 'rocky.pdp_description.promo_bath_bomb' | t }}</p>
      {%- endif -%}
      {%- if tag contains 'earth-promo' -%}
        <p class="r-pdp-description__promo">{{ 'rocky.pdp_description.promo_earth' | t }}</p>
      {%- endif -%}
    {%- endfor -%}

    {%- unless product.type == 'Accessories'
      or product.type == 'Gift Card'
      or product.type == 'Packaging'
      or product.title contains 'Essentials Pouch' -%}
      {%- liquid
        assign meta_parts = ''
        assign meta_parts = meta_parts | append: 'rocky.pdp_description.meta_tested' | t

        if product.metafields.global.organic
          assign organic_html = 'rocky.pdp_description.meta_organic_html' | t: percent: product.metafields.global.organic
          assign meta_parts = meta_parts | append: ' | ' | append: organic_html
        endif

        for tag in product.tags
          if tag contains 'glass'
            assign glass_label = 'rocky.pdp_description.meta_glass' | t
            assign meta_parts = meta_parts | append: ' | ' | append: glass_label
          endif
          if tag contains 'plastic'
            assign plastic_label = 'rocky.pdp_description.meta_plastic' | t
            assign meta_parts = meta_parts | append: ' | ' | append: plastic_label
          endif
        endfor

        if variant.options[1] != blank
          assign meta_parts = meta_parts | append: ' | Size/Weight: ' | append: variant.options[1]
        endif
      -%}
      <p class="r-pdp-description__meta">{{ meta_parts }}</p>
    {%- endunless -%}
  </div>

  <button
    type="button"
    class="r-pdp-description__toggle"
    ref="button"
    on:click="/toggle"
    aria-expanded="false"
  >
    <span class="r-pdp-description__toggle-more">{{ 'actions.show_more' | t }}</span>
    <span class="r-pdp-description__toggle-less">{{ 'actions.show_less' | t }}</span>
  </button>
</r-read-more>

{% stylesheet %}
  .r-pdp-description {
    display: block;
  }

  .r-pdp-description__content {
    overflow: hidden;
  }

  .r-pdp-description__rte + .r-pdp-description__rte {
    margin-block-start: var(--margin-sm, 12px);
  }

  .r-pdp-description__note,
  .r-pdp-description__promo,
  .r-pdp-description__meta {
    margin-block-start: var(--margin-sm, 12px);
    font-size: var(--font-paragraph--size, 0.95rem);
  }

  .r-pdp-description__meta {
    color: rgb(var(--color-foreground-rgb) / 0.6);
    font-size: var(--font-size--xs, 0.8125rem);
  }

  /* Toggle: hidden by default (desktop shows the full description). Revealed on
     mobile via the media query below; hidden again when the copy is short
     enough to fit (data-fits, set by r-read-more.js). */
  .r-pdp-description__toggle {
    display: none;
    align-items: center;
    margin-block-start: var(--margin-sm, 12px);
    padding: 0;
    background: none;
    border: none;
    color: var(--color-foreground);
    font: inherit;
    text-decoration: underline;
    text-underline-offset: 0.2em;
    cursor: pointer;
  }

  .r-pdp-description__toggle-less {
    display: none;
  }

  .r-pdp-description[data-expanded='true'] .r-pdp-description__toggle-more {
    display: none;
  }

  .r-pdp-description[data-expanded='true'] .r-pdp-description__toggle-less {
    display: inline;
  }

  /* Collapsed clamp + toggle are mobile-only; desktop always shows the full
     description with no toggle. */
  @media screen and (max-width: 749px) {
    /* Clamp + fade only when the copy actually overflows — short descriptions
       (data-fits, set by r-read-more.js) must not get a faded bottom edge. */
    .r-pdp-description[data-expanded='false']:not([data-fits]) .r-pdp-description__content {
      max-height: var(--r-pdp-description-clamp, 12em);
      -webkit-mask-image: linear-gradient(to bottom, rgb(0 0 0) 70%, transparent 100%);
      mask-image: linear-gradient(to bottom, rgb(0 0 0) 70%, transparent 100%);
    }

    .r-pdp-description__toggle {
      display: inline-flex;
    }

    .r-pdp-description[data-fits] .r-pdp-description__toggle {
      display: none;
    }
  }

  @media screen and (min-width: 750px) {
    .r-pdp-description__content {
      max-height: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.r_pdp_description",
  "tag": null,
  "settings": [],
  "presets": [
    {
      "name": "t:names.r_pdp_description",
      "category": "Rocky — PDP"
    }
  ]
}
{% endschema %}
