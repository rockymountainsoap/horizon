{%- liquid
  assign scheme = block.settings.color_scheme
  if block.settings.inherit_color_scheme
    assign scheme = section.settings.color_scheme
  endif

  # Each product gets order = (absolute_index) * 2.
  # Each inflow card gets order = position * 2, so the card and the product
  # at the same position share an order value; CSS Grid breaks the tie by
  # DOM source order, and `content_for 'blocks'` is emitted before the
  # product loop in the section, so the card always wins. Result: a card at
  # position N occupies slot N and pushes the product at slot N forward.
  # The grid uses `grid-auto-flow: row dense` (when inflow cells are present)
  # so trailing products backfill any cells the card's span couldn't occupy.
  assign css_order = block.settings.position | times: 2
-%}

<li
  class="product-grid__item r-inflow-cell"
  style="order: {{ css_order }}; --r-inflow-col-span: {{ block.settings.desktop_col_span }}; --r-inflow-row-span: {{ block.settings.desktop_row_span }}; --r-inflow-col-span-mobile: {{ block.settings.mobile_col_span }};"
  data-r-inflow-position="{{ block.settings.position }}"
  {{ block.shopify_attributes }}
>
  <div class="r-inflow-card color-{{ scheme }}">
    {% render 'r-inflow-card-content', block: block %}
  </div>
</li>

{% stylesheet %}
  .r-inflow-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    background-color: var(--color-background);
    color: var(--color-foreground);
    border-radius: var(--style-border-radius-base, 0);
  }

  .r-inflow-card__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: var(--r-inflow-card-media-ratio, 1 / 1);
  }

  .r-inflow-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .r-inflow-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--r-space-2xs, 8px);
    padding: var(--r-space-md, 24px);
    flex: 1;
  }

  .r-inflow-card__heading {
    margin: 0;
    font-family: var(--r-font-display, inherit);
  }

  .r-inflow-card__copy {
    margin: 0;
    line-height: 1.5;
  }

  .r-inflow-card__copy > :first-child { margin-top: 0; }
  .r-inflow-card__copy > :last-child { margin-bottom: 0; }

  .r-inflow-card__cta {
    align-self: start;
    margin-top: auto;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.r_inflow_card",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "t:content.r_inflow_card_placement"
    },
    {
      "type": "collection_list",
      "id": "target_collections",
      "label": "t:settings.r_inflow_card_target_collections",
      "info": "t:settings.r_inflow_card_target_collections_info"
    },
    {
      "type": "number",
      "id": "position",
      "label": "t:settings.r_inflow_card_position",
      "info": "t:settings.r_inflow_card_position_info",
      "default": 4
    },
    {
      "type": "header",
      "content": "t:content.r_inflow_card_layout"
    },
    {
      "type": "range",
      "id": "desktop_col_span",
      "label": "t:settings.r_inflow_card_desktop_col_span",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "select",
      "id": "desktop_row_span",
      "label": "t:settings.r_inflow_card_desktop_row_span",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "mobile_col_span",
      "label": "t:settings.r_inflow_card_mobile_col_span",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "t:content.r_inflow_card_content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:settings.image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading"
    },
    {
      "type": "richtext",
      "id": "body_richtext",
      "label": "t:settings.r_inflow_card_body"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:settings.r_inflow_card_cta_label"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:settings.r_inflow_card_cta_link"
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "t:settings.inherit_color_scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    }
  ],
  "presets": [
    {
      "name": "t:names.r_inflow_card",
      "category": "Rocky — Collection",
      "settings": {
        "position": 4,
        "desktop_col_span": 2,
        "desktop_row_span": "1",
        "mobile_col_span": "2",
        "inherit_color_scheme": true
      }
    }
  ]
}
{% endschema %}
