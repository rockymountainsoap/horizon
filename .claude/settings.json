{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-engine-manifest.sh\"",
            "timeout": 10,
            "statusMessage": "Checking engine manifest…"
          }
        ]
      }
    ]
  }
}
