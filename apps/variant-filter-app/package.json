{
  "name": "variant-filter-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "extensions/*"
  ],
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "shopify app dev",
    "dev:worker": "vite dev",
    "deploy:worker": "npm run build && npx wrangler deploy",
    "deploy:extension": "shopify app deploy",
    "deploy": "npm run deploy:worker && npm run deploy:extension",
    "graphql-codegen": "graphql-codegen",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "dependencies": {
    "@react-router/fs-routes": "7.18.1",
    "@shopify/polaris": "^13.9.5",
    "@shopify/shopify-app-react-router": "^1.2.1",
    "@shopify/shopify-app-session-storage-kv": "^6.0.1",
    "isbot": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "7.18.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/workers-types": "^5.20260717.1",
    "@react-router/dev": "7.18.1",
    "@shopify/api-codegen-preset": "^2.0.1",
    "graphql-config": "^5.1.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vite-tsconfig-paths": "^6.1.1",
    "wrangler": "^4.112.0"
  }
}