{%- # r-fonts.liquid — self-hosted RockyAptaPro (variable) + theme-wide type tokens -%}
{%- # Rendered in theme.liquid AFTER theme-styles-variables so this :root wins the cascade. -%}
{%- # @font-face needs asset_url (Liquid-only), so it cannot live in r-base.css. -%}
{% style %}
  /* Brand face: single variable woff2, all weights 100–800, EN+FR+currency subset.
     Italic axis dropped (design uses none) → 51.8 KB. Faux-italic if ever needed. */
  @font-face {
    font-family: 'RockyAptaPro';
    src: url('{{ 'RockyAptaPro-Var.woff2' | asset_url }}') format('woff2');
    font-weight: 100 800;
    font-style: normal;
    font-display: swap;
  }

  /* Metric-matched fallback → eliminates the swap layout shift (CLS).
     Values measured from RockyAptaPro (upm 1000, typo asc/desc 950/-300, avg advance
     0.507em) vs local Arial (avg advance 0.4895em): size-adjust matches glyph width so
     wrapped text keeps the same line breaks; ascent/descent overrides pin the line box. */
  @font-face {
    font-family: 'RockyAptaPro Fallback';
    src: local('Arial');
    size-adjust: 103.6%;
    ascent-override: 95%;
    descent-override: 30%;
    line-gap-override: 0%;
  }

  :root {
    /* ── Theme-wide family swap ─────────────────────────────────────────────
       The four SOURCE families cascade to every heading, paragraph, button and
       cart via var() indirection in theme-styles-variables.liquid. */
    --font-body--family: 'RockyAptaPro', 'RockyAptaPro Fallback', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    --font-subheading--family: var(--font-body--family);
    --font-heading--family: var(--font-body--family);
    --font-accent--family: var(--font-body--family);

    /* ── Global type scale (Figma parity, E1) ───────────────────────────────
       Fixed px (rem = px/16), weight 400, tracking tight (0.02em), no case.
       Overrides the generated --font-{preset}--* tokens (this block renders after
       the generator). Headings are deliberately Regular 400 per the design. */
    --font-h1--size: 1.875rem;   /* 30px */
    --font-h1--line-height: 1.33;
    --font-h1--weight: 400;
    --font-h1--letter-spacing: var(--r-tracking-tight);
    --font-h1--case: none;

    --font-h2--size: 1.5rem;     /* 24px */
    --font-h2--line-height: 1.35;
    --font-h2--weight: 400;
    --font-h2--letter-spacing: var(--r-tracking-tight);
    --font-h2--case: none;

    --font-h3--size: 1.25rem;    /* 20px */
    --font-h3--line-height: 1.4;
    --font-h3--weight: 400;
    --font-h3--letter-spacing: var(--r-tracking-tight);
    --font-h3--case: none;

    --font-h4--size: 1.125rem;   /* 18px */
    --font-h4--line-height: 1.4;
    --font-h4--weight: 400;
    --font-h4--letter-spacing: var(--r-tracking-tight);
    --font-h4--case: none;

    --font-h5--size: 1rem;       /* 16px */
    --font-h5--line-height: 1.4;
    --font-h5--weight: 400;
    --font-h5--letter-spacing: var(--r-tracking-tight);
    --font-h5--case: none;

    --font-h6--size: 0.875rem;   /* 14px */
    --font-h6--line-height: 1.45;
    --font-h6--weight: 400;
    --font-h6--letter-spacing: var(--r-tracking-tight);
    --font-h6--case: none;

    --font-paragraph--size: 0.75rem;  /* 12px — floored from Figma 11px body */
    --font-paragraph--line-height: 1.6;
    --font-paragraph--weight: 400;
    --font-paragraph--letter-spacing: var(--r-tracking-tight);
    --font-paragraph--case: none;
  }
{% endstyle %}
