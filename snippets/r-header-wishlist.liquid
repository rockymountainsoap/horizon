{%- comment -%}
  Snippet: r-header-wishlist
  Workstream: WS0 — Native Wishlist
  Description: Heart icon in the header with count badge and slide-in mini-wishlist drawer.
               Guests see their localStorage list; logged-in customers fetch via App Proxy.
{%- endcomment -%}

<r-wishlist-header
  class="r-wishlist-header header-actions__action"
  data-logged-in="{% if customer %}true{% else %}false{% endif %}"
  data-proxy-base="/apps/wishlist"
  data-account-url="/account"
>
  <button
    type="button"
    class="r-wishlist-header__btn button-unstyled"
    aria-label="{{ 'rocky.wishlist.open_drawer' | t: default: 'Open wishlist' }}"
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="r-wishlist-dialog"
  >
    <span class="svg-wrapper" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        class="r-wishlist-header__icon"
        focusable="false"
      >
        <path
          class="r-wishlist-header__icon-path"
          d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linejoin="round"
        />
      </svg>
    </span>
    <span
      class="r-wishlist-header__badge"
      aria-live="polite"
      aria-label="{{ 'rocky.wishlist.item_count' | t: default: 'items in wishlist' }}"
      hidden
    >0</span>
  </button>

  <dialog
    id="r-wishlist-dialog"
    class="r-wishlist-dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}"
    aria-labelledby="r-wishlist-dialog-heading"
    data-skip-subtree-update
    scroll-lock
  >
    <div class="r-wishlist-dialog__inner">
      <div class="r-wishlist-dialog__header">
        <h2
          class="r-wishlist-dialog__heading h4"
          id="r-wishlist-dialog-heading"
          tabindex="-1"
        >
          {{ 'rocky.wishlist.heading' | t: default: 'My Wishlist' }}
          <span class="r-wishlist-dialog__count-label"></span>
        </h2>
        <button
          type="button"
          class="button close-button r-wishlist-dialog__close button-unstyled"
          aria-label="{{ 'actions.close_dialog' | t }}"
        >
          <span class="svg-wrapper">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>

      <div class="r-wishlist-dialog__content" aria-live="polite" aria-busy="false">
        <div class="r-wishlist-dialog__loading">
          <span class="r-wishlist-dialog__spinner" aria-hidden="true"></span>
          <span class="visually-hidden">{{ 'accessibility.loading' | t }}</span>
        </div>
        <ul class="r-wishlist-dialog__list" role="list"></ul>
        <p class="r-wishlist-dialog__empty" hidden>
          {{ 'rocky.wishlist.empty' | t: default: 'Your wishlist is empty.' }}
        </p>
        <p class="r-wishlist-dialog__guest-note" hidden>
          {{ 'rocky.wishlist.guest_note' | t: default: 'Log in to save your wishlist across devices.' }}
        </p>
      </div>

      <div class="r-wishlist-dialog__footer">
        <a
          href="/account"
          class="button r-wishlist-dialog__view-all"
          hidden
        >
          {{ 'rocky.wishlist.view_all' | t: default: 'View full wishlist' }}
        </a>
      </div>
    </div>
  </dialog>
</r-wishlist-header>

<style>
  r-wishlist-header {
    display: flex;
    align-items: center;
  }

  .r-wishlist-header__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-width: 44px;
    min-height: 44px;
    cursor: pointer;
    color: var(--color-foreground);
  }

  .r-wishlist-header__btn:focus-visible {
    outline: 0.2rem solid rgba(var(--color-foreground), 0.5);
    outline-offset: 0.3rem;
    border-radius: var(--style-border-radius-buttons-primary);
  }

  .r-wishlist-header__icon-path {
    transition: fill 0.2s ease;
  }

  r-wishlist-header[data-has-items] .r-wishlist-header__icon-path {
    fill: currentColor;
  }

  .r-wishlist-header__badge {
    position: absolute;
    top: 4px;
    right: 2px;
    min-width: 17px;
    height: 17px;
    padding: 0 4px;
    background: var(--color-primary-button-background, #000);
    color: var(--color-primary-button-text, #fff);
    font-size: 10px;
    font-weight: 600;
    line-height: 17px;
    border-radius: 9px;
    text-align: center;
    pointer-events: none;
  }

  /* ── Drawer shell — mirrors .cart-drawer__dialog exactly ── */
  .r-wishlist-dialog {
    --r-wishlist-padding: var(--padding-xl);
    --r-wishlist-padding-desktop: var(--padding-2xl);

    position: fixed;
    overflow: hidden;
    border-radius: 0;
    width: 100%;
    height: 100%;
    margin: 0 0 0 auto;
    padding: 0;
    border-left: var(--style-border-drawer);
    box-shadow: var(--shadow-drawer);
    background-color: var(--color-background);
  }

  @media screen and (min-width: 750px) {
    .r-wishlist-dialog {
      width: var(--sidebar-width);
      max-width: 95vw;
    }
  }

  /* Override dialog-modal mobile overrides that would break the drawer */
  .r-wishlist-dialog:modal {
    max-height: 100dvh;
    max-width: unset;
    height: 100%;
    width: 100%;
    padding: 0;
    overflow-y: hidden;
  }

  @media screen and (min-width: 750px) {
    .r-wishlist-dialog:modal {
      width: var(--sidebar-width);
      max-width: 95vw;
    }
  }

  /* ── Inner layout — mirrors .cart-drawer__inner ── */
  .r-wishlist-dialog__inner {
    height: 100%;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ── Header — mirrors .cart-drawer__header ── */
  .r-wishlist-dialog__header {
    background-color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--r-wishlist-padding);
    border-bottom: var(--style-border-width) solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 1;
    flex-shrink: 0;
  }

  @media screen and (min-width: 750px) {
    .r-wishlist-dialog__header {
      padding-inline: var(--r-wishlist-padding-desktop);
    }
  }

  /* ── Heading — mirrors .cart-drawer__heading ── */
  .r-wishlist-dialog__heading {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
    margin-bottom: 0;
  }

  .r-wishlist-dialog__heading:focus-visible {
    outline: 0.2rem solid rgba(var(--color-foreground), 0.5);
    outline-offset: 0.2rem;
    border-radius: 2px;
  }

  .r-wishlist-dialog__count-label {
    font-weight: 400;
    opacity: 0.6;
    font-size: 0.875em;
  }

  /* ── Content area — mirrors .cart-drawer__content ── */
  .r-wishlist-dialog__content {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: 0;
    background-color: var(--color-background);
    overflow-y: auto;
  }

  /* ── Loading state ── */
  /* Hidden by default; shown via JS class toggle so display: flex doesn't
     fight the [hidden] attribute's display: none. */
  .r-wishlist-dialog__loading {
    display: none;
    justify-content: center;
    padding: var(--padding-3xl, 3rem) 0;
  }

  .r-wishlist-dialog__loading--visible {
    display: flex;
  }

  .r-wishlist-dialog__spinner {
    width: 24px;
    height: 24px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-foreground);
    border-radius: 50%;
    animation: r-spin 0.7s linear infinite;
  }

  @keyframes r-spin {
    to { transform: rotate(360deg); }
  }

  /* ── Product list — mirrors .cart-drawer__items ── */
  .r-wishlist-dialog__list {
    list-style: none;
    margin: 0;
    padding: var(--r-wishlist-padding);
    display: flex;
    flex-direction: column;
    gap: var(--gap-xl);
    overflow-y: auto;
    flex: 1;
  }

  @media screen and (min-width: 750px) {
    .r-wishlist-dialog__list {
      padding-inline: var(--r-wishlist-padding-desktop);
    }
  }

  /* ── Product row ── */
  .r-wishlist-item {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    gap: var(--gap-md, 1.2rem);
    align-items: start;
    padding-bottom: var(--gap-xl);
    border-bottom: var(--style-border-width) solid var(--color-border);
  }

  .r-wishlist-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .r-wishlist-item__image-link {
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: var(--style-border-radius-buttons-primary, 4px);
    background: var(--color-background-contrast, #f5f5f5);
    flex-shrink: 0;
  }

  .r-wishlist-item__image-link:focus-visible {
    outline: 0.2rem solid rgba(var(--color-foreground), 0.5);
    outline-offset: 0.2rem;
  }

  .r-wishlist-item__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .r-wishlist-item__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-border);
  }

  .r-wishlist-item__info {
    display: flex;
    flex-direction: column;
    gap: var(--gap-2xs, 0.4rem);
    min-width: 0;
  }

  .r-wishlist-item__title {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-foreground);
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .r-wishlist-item__title:hover {
    text-decoration: underline;
  }

  .r-wishlist-item__title:focus-visible {
    outline: 0.2rem solid rgba(var(--color-foreground), 0.5);
    outline-offset: 0.2rem;
    border-radius: 2px;
  }

  .r-wishlist-item__price {
    font-size: 0.85rem;
    opacity: 0.7;
  }

  .r-wishlist-item__sold-out {
    font-size: 0.75rem;
    color: var(--color-error, #c0392b);
  }

  /* ── Variant selector ── */
  .r-wishlist-item__variant-select {
    width: 100%;
    padding: 0.3rem 0.5rem;
    font-size: 0.8rem;
    color: var(--color-foreground);
    background: var(--color-background);
    border: var(--style-border-width, 1px) solid var(--color-border);
    border-radius: var(--style-border-radius-inputs, 4px);
    cursor: pointer;
    appearance: auto;
  }

  .r-wishlist-item__variant-select:focus-visible {
    outline: 0.2rem solid rgba(var(--color-foreground), 0.5);
    outline-offset: 0.2rem;
  }

  /* ── Bottom row: price + ATC side-by-side ── */
  .r-wishlist-item__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-xs, 0.5rem);
    flex-wrap: wrap;
    margin-top: 0.1rem;
  }

  /* ── Add to cart button ── */
  .r-wishlist-item__atc {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.2;
    cursor: pointer;
    white-space: nowrap;
    border-radius: var(--style-border-radius-buttons-primary, 4px);
    background: var(--color-primary-button-background, #000);
    color: var(--color-primary-button-text, #fff);
    border: 1px solid var(--color-primary-button-background, #000);
    transition: opacity 0.15s ease;
  }

  .r-wishlist-item__atc:hover:not(:disabled) {
    opacity: 0.85;
  }

  .r-wishlist-item__atc:focus-visible {
    outline: 0.2rem solid rgba(var(--color-foreground), 0.5);
    outline-offset: 0.2rem;
  }

  .r-wishlist-item__atc:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .r-wishlist-item__remove {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: var(--color-foreground);
    opacity: 0.5;
    flex-shrink: 0;
    border-radius: 50%;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.15s ease;
  }

  .r-wishlist-item__remove:hover {
    opacity: 1;
  }

  .r-wishlist-item__remove:focus-visible {
    outline: 0.2rem solid rgba(var(--color-foreground), 0.5);
    outline-offset: 0.2rem;
    border-radius: 50%;
    opacity: 1;
  }

  /* ── Empty / guest states ── */
  .r-wishlist-dialog__empty,
  .r-wishlist-dialog__guest-note {
    text-align: center;
    padding: var(--padding-3xl, 3rem) var(--r-wishlist-padding);
    opacity: 0.6;
    font-size: 0.9rem;
  }

  /* ── Footer CTA — mirrors .cart-drawer__summary ── */
  .r-wishlist-dialog__footer {
    position: sticky;
    bottom: 0;
    z-index: 1;
    flex-shrink: 0;
    padding: var(--r-wishlist-padding);
    background-color: var(--color-background);
    border-top: var(--style-border-width) solid var(--color-border);
    mask-image: linear-gradient(to bottom, transparent, black var(--r-wishlist-padding));
  }

  @media screen and (min-width: 750px) {
    .r-wishlist-dialog__footer {
      padding: var(--r-wishlist-padding-desktop);
    }
  }

  .r-wishlist-dialog__view-all {
    display: block;
    width: 100%;
    text-align: center;
  }

  /* ── Close button — mirrors .cart-drawer__close-button ── */
  .r-wishlist-dialog__close {
    margin-right: calc(var(--padding-sm) * -1);
  }

  /* ── Windows High Contrast Mode ── */
  @media (forced-colors: active) {
    .r-wishlist-dialog {
      outline: 2px solid transparent;
    }

    .r-wishlist-header__btn:focus-visible,
    .r-wishlist-dialog__close:focus-visible {
      outline: 2px solid transparent;
    }
  }
</style>

<script src="{{ 'r-header-wishlist.js' | asset_url }}" defer></script>
