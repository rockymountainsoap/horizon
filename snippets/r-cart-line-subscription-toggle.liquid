{% doc %}
  Rocky — Cart Line Subscription Toggle

  Renders a toggle switch on a cart line item that converts it between a
  one-time purchase and the variant's first selling plan (Loop subscription).
  Renders nothing if the variant has no selling plans available.

  @param {object} item - A cart line item.

  @example
  {% render 'r-cart-line-subscription-toggle', item: item %}
{% enddoc %}

{%- if item.variant.selling_plan_allocations.size > 0 -%}
  {%- liquid
    assign first_allocation = item.variant.selling_plan_allocations.first
    assign first_plan = first_allocation.selling_plan
    assign is_active = false
    if item.selling_plan_allocation
      assign is_active = true
    endif
  -%}

  <r-cart-line-subscription-toggle
    class="r-cart-subscribe{% if is_active %} r-cart-subscribe--active{% endif %}"
    data-line-key="{{ item.key }}"
    data-selling-plan-id="{{ first_plan.id }}"
    data-active="{{ is_active }}"
  >
    <button
      type="button"
      role="switch"
      class="r-cart-subscribe__switch"
      aria-checked="{{ is_active }}"
      aria-label="{{ 'rocky.cart.subscribe.aria_label' | t }}"
      data-r-cart-subscribe-trigger
    >
      <span class="r-cart-subscribe__track" aria-hidden="true">
        <span class="r-cart-subscribe__thumb"></span>
      </span>
    </button>
    <span class="r-cart-subscribe__label">
      {%- if is_active -%}
        {{ 'rocky.cart.subscribe.active' | t }}
      {%- else -%}
        {{ 'rocky.cart.subscribe.cta' | t }}
      {%- endif -%}
    </span>
  </r-cart-line-subscription-toggle>
{%- endif -%}

{% stylesheet %}
  .r-cart-subscribe {
    --r-cart-subscribe-track-width: 32px;
    --r-cart-subscribe-track-height: 18px;
    --r-cart-subscribe-thumb-size: 14px;
    --r-cart-subscribe-track-bg: var(--color-border);
    --r-cart-subscribe-track-bg-active: var(--color-foreground);
    --r-cart-subscribe-thumb-bg: var(--color-background);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-block-start: 6px;
    font-size: var(--font-size--xs);
    line-height: 1.3;
  }

  .r-cart-subscribe__switch {
    appearance: none;
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    flex-shrink: 0;
    inline-size: var(--r-cart-subscribe-track-width);
    block-size: var(--r-cart-subscribe-track-height);
    border-radius: calc(var(--r-cart-subscribe-track-height) / 2);
  }

  .r-cart-subscribe__switch:disabled {
    opacity: 0.5;
    cursor: progress;
  }

  .r-cart-subscribe__switch:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .r-cart-subscribe__track {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    background: var(--r-cart-subscribe-track-bg);
    border-radius: inherit;
    position: relative;
    transition: background-color 160ms ease;
  }

  .r-cart-subscribe--active .r-cart-subscribe__track {
    background: var(--r-cart-subscribe-track-bg-active);
  }

  .r-cart-subscribe__thumb {
    position: absolute;
    inset-block-start: 50%;
    inset-inline-start: 2px;
    inline-size: var(--r-cart-subscribe-thumb-size);
    block-size: var(--r-cart-subscribe-thumb-size);
    background: var(--r-cart-subscribe-thumb-bg);
    border-radius: 50%;
    transform: translateY(-50%);
    transition: inset-inline-start 160ms ease;
  }

  .r-cart-subscribe--active .r-cart-subscribe__thumb {
    inset-inline-start: calc(
      var(--r-cart-subscribe-track-width)
      - var(--r-cart-subscribe-thumb-size)
      - 2px
    );
  }

  .r-cart-subscribe__label {
    color: var(--color-foreground);
  }

  .r-cart-subscribe[data-busy='true'] {
    pointer-events: none;
  }
{% endstylesheet %}
