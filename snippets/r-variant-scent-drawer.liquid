{%- doc -%}
  Rocky combined-listing Scent selector, rendered as a right-side drawer instead
  of a native <select>. Used only for the combined-listing (Scent) option in
  variant-main-picker.liquid; the merchant "Dropdowns" style keeps
  variant-option-dropdown.liquid.

  Behaviour is preserved verbatim: a real (visually hidden) <select> stays inside
  <variant-picker> so its `change` still bubbles to variant-picker.js
  `variantChanged()` (combined-listing morph + history update). The drawer's scent
  buttons drive that select via r-scent-drawer.js — no engine changes.

  @param {object} product_option - The combined-listing option (its values carry product_url).
  @param {object} block - The variants block, for id namespacing.
  @param {number} option_index - forloop.index0 of the option, for unique ids.
{%- enddoc -%}

{%- liquid
  assign current_value = product_option.selected_value
  assign select_id = 'Option-' | append: block.id | append: '-' | append: option_index
  assign drawer_id = 'r-scent-' | append: block.id | append: '-' | append: option_index
-%}

<r-scent-drawer class="variant-option variant-option--dropdowns r-scent-drawer">
  {%- # The visible row label. Not a <label for>: the real select is aria-hidden
    # and the interactive control is the trigger button, whose accessible name
    # carries the option name itself. -%}
  <span class="r-scent-drawer__label" aria-hidden="true">{{ product_option.name | escape }}</span>

  {%- # Real native select — visually hidden, kept inside <variant-picker> so a
    # dispatched `change` reaches variantChanged() unchanged. -%}
  <select
    id="{{ select_id }}"
    name="options[{{ product_option.name | escape }}]"
    class="r-scent-drawer__select visually-hidden"
    tabindex="-1"
    aria-hidden="true"
    data-r-scent-select
  >
    {%- for product_option_value in product_option.values -%}
      <option
        value="{{ product_option_value | escape }}"
        data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
        data-option-value-id="{{ product_option_value.id }}"
        data-variant-id="{{ product_option_value.variant.id }}"
        data-connected-product-url="{{ product_option_value.product_url }}"
        {% if product_option_value.selected %}selected="selected"{% endif %}
      >
        {{ product_option_value | escape }}
      </option>
    {%- endfor -%}
  </select>

  {%- capture scent_trigger -%}
    <button
      type="button"
      class="r-scent-drawer__trigger"
      on:click="/showDialog"
      aria-haspopup="dialog"
    >
      {%- # Accessible name reads "Scent Cedarwood" — option name + current value. -%}
      <span class="visually-hidden">{{ product_option.name | escape }}</span>
      <span class="r-scent-drawer__current">{{ current_value }}</span>
      <svg aria-hidden="true" focusable="false" class="icon icon-caret" viewBox="0 0 10 6">
        {%- render 'icon', icon: 'caret' -%}
      </svg>
    </button>
  {%- endcapture -%}

  {%- capture scent_list -%}
    <ul class="r-scent-drawer__list">
      {%- for product_option_value in product_option.values -%}
        <li class="r-scent-drawer__item">
          <button
            type="button"
            class="r-scent-drawer__option"
            data-r-scent-value="{{ product_option_value | escape }}"
            {% if product_option_value.selected %}aria-current="true"{% endif %}
            {% if product_option_value.available == false %}data-unavailable="true"{% endif %}
          >
            <span class="r-scent-drawer__option-name">{{ product_option_value | escape }}</span>
            {%- if product_option_value.available == false -%}
              <span class="r-scent-drawer__option-status">{{ 'content.unavailable' | t }}</span>
            {%- endif -%}
          </button>
        </li>
      {%- endfor -%}
    </ul>
  {%- endcapture -%}

  {% render 'r-side-drawer',
    id: drawer_id,
    heading: product_option.name,
    trigger: scent_trigger,
    content: scent_list
  %}

  <script src="{{ 'r-scent-drawer.js' | asset_url }}" type="module"></script>
</r-scent-drawer>

{% stylesheet %}
  /* The wrapper reuses the shared option-row grid (.variant-option--dropdowns in
     r-base.css): label column + value column + bottom rule. The dialog-component
     is the value-column grid item; the trigger fills it. */
  .r-scent-drawer > dialog-component {
    display: block;
    min-width: 0;
  }

  .r-scent-drawer__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--r-space-sm, 16px);
    width: 100%;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    /* Row value — matches SIZE / SKIN TYPE (PDP value tier, cascades from
       .product-details). */
    font-size: var(--r-pdp-value-size, var(--font-size--sm, 0.875rem));
    color: var(--color-foreground);
    text-align: start;
  }

  .r-scent-drawer__trigger .icon-caret {
    flex: 0 0 auto;
    width: var(--icon-size-2xs, 0.75rem);
    height: var(--icon-size-2xs, 0.75rem);
    color: rgb(var(--color-foreground-rgb) / 0.6);
  }

  .r-scent-drawer__trigger:focus-visible {
    outline: var(--focus-outline-width, 2px) solid var(--color-foreground);
    outline-offset: 3px;
  }

  /* Drawer body — scent list */
  .r-scent-drawer__list {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .r-scent-drawer__option {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--r-space-sm, 16px);
    width: 100%;
    min-height: var(--minimum-touch-target, 44px);
    padding: var(--r-space-sm, 16px) 0;
    border: none;
    border-block-end: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
    background: transparent;
    cursor: pointer;
    font-size: var(--r-pdp-value-size, var(--font-size--sm, 0.875rem));
    color: var(--color-foreground);
    text-align: start;
  }

  .r-scent-drawer__option[aria-current='true'] .r-scent-drawer__option-name {
    text-decoration: underline;
    text-underline-offset: 0.2em;
    font-weight: 600;
  }

  .r-scent-drawer__option[data-unavailable='true'] {
    color: rgb(var(--color-foreground-rgb) / 0.45);
  }

  .r-scent-drawer__option-status {
    font-size: var(--r-pdp-label-size, var(--font-size--xs, 0.8125rem));
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .r-scent-drawer__option:hover .r-scent-drawer__option-name {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .r-scent-drawer__option:focus-visible {
    outline: var(--focus-outline-width, 2px) solid var(--color-foreground);
    outline-offset: -2px;
  }
{% endstylesheet %}
