# =============================================================================
# macOS
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# =============================================================================
# Editor / IDE
# =============================================================================
.idea/
*.sublime-project
*.sublime-workspace
# Cursor/Claude session data (auto-generated, local only)
.claude/

.cursor/temp/

# =============================================================================
# Environment & secrets
# =============================================================================
.env
.env.*
!.env.example
# Cloudflare Workers local secrets
**/.dev.vars

# =============================================================================
# Dependencies
# =============================================================================
node_modules/
**/node_modules/

# =============================================================================
# Build output
# =============================================================================
dist/
**/dist/

# Remix / Vite build output (variant-filter-app)
apps/variant-filter-app/build/

# =============================================================================
# Cloudflare Wrangler
# =============================================================================
# Root-level .wrangler (created by `wrangler dev` at repo root, if ever run)
.wrangler/
# Per-package .wrangler directories
apps/**/.wrangler/
workers/**/.wrangler/

# =============================================================================
# Shopify CLI
# =============================================================================
# .shopify dirs hold CLI session tokens and dev-server state — never commit
.shopify/
apps/**/.shopify/
workers/**/.shopify/

# =============================================================================
# Logs & temp files
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.tmp/
tmp/
